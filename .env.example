# Solana RPC endpoint used by the signer server.
SAW_RPC_URL=https://api.devnet.solana.com

# API signer server. The admin dashboard is allowed to call this origin only.
SAW_API_HOST=127.0.0.1
SAW_API_PORT=3001

# Local admin dashboard. WebAuthn requires localhost or HTTPS.
SAW_DASHBOARD_HOST=127.0.0.1
SAW_DASHBOARD_PORT=8080
SAW_DASHBOARD_ORIGIN=http://localhost:8080

# WebAuthn relying party settings.
SAW_RP_ID=localhost
SAW_RP_NAME=Solana Agent Wallet

# SQLite database location.
SAW_DB_PATH=./data/agent-wallet.sqlite
